# ═══════════════════════════════════════════════════════════════════════════
# KPOS - Docker Compose Environment
# ═══════════════════════════════════════════════════════════════════════════

NODE_ENV=development

# ═══════════════════════════════════════════════════════════════════════════
# Service Ports
# ═══════════════════════════════════════════════════════════════════════════
API_PORT=5000
FRONTEND_PORT=3000
MONGO_PORT=27017
REDIS_PORT=6379
RABBITMQ_PORT=5672
RABBITMQ_MANAGEMENT_PORT=15672
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443

# ═══════════════════════════════════════════════════════════════════════════
# RabbitMQ Credentials
# ═══════════════════════════════════════════════════════════════════════════
RABBITMQ_USER=kpos
RABBITMQ_PASS=kpos_secret

# ═══════════════════════════════════════════════════════════════════════════
# JWT Configuration (min 32 characters)
# ═══════════════════════════════════════════════════════════════════════════
JWT_SECRET=kpos-dev-secret-key-change-in-production-2024-must-be-32-chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

