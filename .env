# ═══════════════════════════════════════════════════════════════════════════
# KPOS Environment Configuration
# ═══════════════════════════════════════════════════════════════════════════

# Application
NODE_ENV=development
API_PORT=5000
FRONTEND_PORT=3000

# Database (PostgreSQL)
DATABASE_URL=postgresql://kpos:password@localhost:5432/kpos_db
POSTGRES_DB=kpos_db
POSTGRES_USER=kpos
POSTGRES_PASSWORD=password
POSTGRES_PORT=5432

# Redis Cache
REDIS_URL=redis://localhost:6379
REDIS_PORT=6379

# RabbitMQ Message Queue
RABBITMQ_URL=amqp://localhost:5672
RABBITMQ_USER=kpos
RABBITMQ_PASS=password
RABBITMQ_PORT=5672
RABBITMQ_MANAGEMENT_PORT=15672

# JWT Configuration
JWT_SECRET=kpos-dev-secret-key-change-in-production-2024-must-be-32-chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Nginx (Production)
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443

# Cloudinary (Image Upload)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER=kpos

# Legacy MongoDB (kept for reference, not used)
MONGO_PORT=27017

# MySQL (kept for reference, not used)
MYSQL_DB=kpos_db
MYSQL_USER=kpos
MYSQL_PASSWORD=password
MYSQL_ROOT_PASSWORD=root
MYSQL_PORT=3306
