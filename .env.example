# ═══════════════════════════════════════════════════════════════════════════
# KPOS Environment Configuration - Example
# Used by docker-compose.yml. Copy to .env and fill in real values before
# deploying — vars marked "must be set" have no insecure fallback and will
# fail the compose/app startup if left unset.
# ═══════════════════════════════════════════════════════════════════════════

# Application
NODE_ENV=development
API_PORT=5000
FRONTEND_PORT=3000

# Database (PostgreSQL)
# POSTGRES_PASSWORD: the superuser `kpos` role, used only by the one-shot
# `migrate` service (DDL/migrations). POSTGRES_APP_PASSWORD: the
# least-privilege `kpos_app` role the running `api` service actually connects
# as, so Row-Level Security policies apply. Both required — no fallback.
POSTGRES_DB=kpos_db
POSTGRES_USER=kpos
POSTGRES_PASSWORD=
POSTGRES_APP_PASSWORD=
POSTGRES_PORT=5432

# Redis Cache
REDIS_PORT=6379

# RabbitMQ Message Queue
RABBITMQ_USER=kpos
RABBITMQ_PASS=
RABBITMQ_PORT=5672
RABBITMQ_MANAGEMENT_PORT=15672

# JWT Configuration — keep in sync with SESSION_ABSOLUTE_HOURS (APIS/env.example)
JWT_SECRET=
JWT_EXPIRES_IN=20h
JWT_REFRESH_EXPIRES_IN=20h
SESSION_ABSOLUTE_HOURS=20

# Per-tenant config encryption + audit checksum keys — deliberately separate
# from JWT_SECRET and from each other (rotating one must not affect the
# others). Generate each with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CONFIG_ENCRYPTION_KEY=
AUDIT_HMAC_SECRET=

# CORS — comma-separated explicit origin allow-list, required in production
CORS_ORIGIN=https://your-domain.example

# Frontend build-time API URL (baked into the client bundle)
PUBLIC_API_URL=https://your-domain.example/api/v1

# Nginx (Production profile)
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443

# Let's Encrypt (TLS) — see scripts/init-letsencrypt.sh. DOMAIN must be a
# real public domain already pointed at this VPS.
DOMAIN=your-domain.example
LETSENCRYPT_EMAIL=admin@your-domain.example

# Cloudinary (Image Upload)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER=kpos

# Seed Admin (for npm run db:seed)
SEED_ADMIN_EMAIL=admin@kpos.la
SEED_ADMIN_PASSWORD=Admin@123456
SEED_ADMIN_NAME=Super Admin
