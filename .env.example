# KPOS Environment Variables
# Copy this file to .env and update the values as needed

# Application
NODE_ENV=development
API_PORT=5000
FRONTEND_PORT=3000

# Security
JWT_SECRET=kpos-dev-secret-key-change-in-production-2024-must-be-32-chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# MongoDB
MONGO_PORT=27017

# Redis
REDIS_PORT=6379

# RabbitMQ
RABBITMQ_PORT=5672
RABBITMQ_MANAGEMENT_PORT=15672
RABBITMQ_USER=kpos
RABBITMQ_PASS=kpos_secret

# PostgreSQL 18
POSTGRES_PORT=5432
POSTGRES_DB=kpos_db
POSTGRES_USER=kpos
POSTGRES_PASSWORD=kpos_secret

# MySQL 8.4
MYSQL_PORT=3306
MYSQL_DB=kpos_db
MYSQL_USER=kpos
MYSQL_PASSWORD=kpos_secret
MYSQL_ROOT_PASSWORD=kpos_root_secret

# Nginx (Production)
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443
