{
    "name": "kpos-api",
    "version": "1.0.0",
    "description": "KPOS - Enterprise Point of Sale System API",
    "author": "KAILO",
    "license": "MIT",
    "type": "module",
    "main": "src/index.ts",
    "scripts": {
        "dev": "tsx watch src/index.ts",
        "start": "tsx src/index.ts",
        "build": "node scripts/build.mjs",
        "build:clean": "node scripts/build.mjs --clean",
        "start:prod": "NODE_ENV=production node dist/index.js",
        "db:generate": "drizzle-kit generate",
        "db:push": "drizzle-kit push",
        "db:migrate": "drizzle-kit migrate",
        "db:studio": "drizzle-kit studio",
        "db:seed": "tsx src/db/seed-demo.ts",
        "db:seed:demo": "tsx src/db/seed-demo.ts",
        "db:seed:prod": "tsx src/db/seed-prod.ts",
        "db:reset": "tsx src/db/seed-reset.ts",
        "test": "vitest",
        "test:watch": "vitest --watch",
        "test:coverage": "vitest --coverage",
        "lint": "eslint src --ext .ts",
        "lint:fix": "eslint src --ext .ts --fix",
        "format": "prettier --write \"src/**/*.ts\"",
        "typecheck": "tsc --noEmit"
    },
    "dependencies": {
        "@getbrevo/brevo": "^5.0.4",
        "@opentelemetry/api": "^1.9.1",
        "@opentelemetry/auto-instrumentations-node": "^0.78.0",
        "@opentelemetry/exporter-metrics-otlp-http": "^0.220.0",
        "@opentelemetry/exporter-trace-otlp-http": "^0.220.0",
        "@opentelemetry/resources": "^2.9.0",
        "@opentelemetry/sdk-metrics": "^2.9.0",
        "@opentelemetry/sdk-node": "^0.220.0",
        "@opentelemetry/sdk-trace-node": "^2.9.0",
        "@opentelemetry/semantic-conventions": "^1.43.0",
        "@socket.io/redis-adapter": "^8.3.0",
        "@types/multer": "^2.1.0",
        "@types/nodemailer": "^8.0.1",
        "amqplib": "^2.0.1",
        "argon2": "^0.31.2",
        "bullmq": "^5.1.0",
        "cloudinary": "^2.9.0",
        "cookie-parser": "^1.4.6",
        "cors": "^2.8.5",
        "dotenv": "^17.2.3",
        "drizzle-orm": "^0.39.0",
        "express": "^5.2.1",
        "express-rate-limit": "^7.1.5",
        "helmet": "^7.1.0",
        "ioredis": "^5.3.2",
        "jsonwebtoken": "^9.0.2",
        "multer": "^2.1.1",
        "node-cron": "^4.5.0",
        "nodemailer": "^9.0.3",
        "openid-client": "^6.8.4",
        "pino": "^8.17.2",
        "pino-pretty": "^10.3.1",
        "postgres": "^3.4.5",
        "prom-client": "^15.1.3",
        "rate-limit-redis": "^4.2.1",
        "socket.io": "^4.7.4",
        "swagger-ui-express": "^5.0.0",
        "uuid": "^9.0.1",
        "web-push": "^3.6.7",
        "xlsx": "^0.18.5",
        "zod": "^3.22.4"
    },
    "devDependencies": {
        "@types/amqplib": "^0.10.8",
        "@types/cookie-parser": "^1.4.7",
        "@types/cors": "^2.8.17",
        "@types/express": "^5.0.6",
        "@types/jsonwebtoken": "^9.0.5",
        "@types/node-cron": "^3.0.11",
        "@types/pg": "^8.11.0",
        "@types/swagger-ui-express": "^4.1.6",
        "@types/uuid": "^9.0.7",
        "@types/web-push": "^3.6.4",
        "@typescript-eslint/eslint-plugin": "^6.19.0",
        "@typescript-eslint/parser": "^6.19.0",
        "@vitest/coverage-v8": "^4.1.8",
        "drizzle-kit": "^0.30.0",
        "eslint": "^8.56.0",
        "eslint-config-prettier": "^9.1.0",
        "eslint-plugin-prettier": "^5.1.3",
        "prettier": "^3.2.4",
        "tsc-alias": "^1.9.0",
        "tsconfig-paths": "^4.2.0",
        "tsx": "^4.21.0",
        "typescript": "^5.3.3",
        "vitest": "^4.1.9"
    }
}
