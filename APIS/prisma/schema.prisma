// ═══════════════════════════════════════════════════════════════════════════
// KPOS - Prisma Schema for MongoDB
// ═══════════════════════════════════════════════════════════════════════════

generator client {
    provider = "prisma-client-js"
}

datasource db {
    provider = "mongodb"
    url = env("DATABASE_URL")
}

// ═══════════════════════════════════════════════════════════════════════════
// AUTHENTICATION & USERS
// ═══════════════════════════════════════════════════════════════════════════

model User {
    id            String    @id @default(auto()) @map("_id") @db.ObjectId
    email         String    @unique
    password      String
    name          String
    phone         String?
    avatar        String?
    role          String    @default("staff")
    roleId        String?   @db.ObjectId
    branchId      String    @db.ObjectId
    permissions   String[]  @default([])  // User-specific permissions (override role)
    isActive      Boolean   @default(true)
    isSuperAdmin  Boolean   @default(false)  // Super Admin flag
    emailVerified Boolean   @default(false)
    twoFAEnabled  Boolean   @default(false)
    twoFASecret   String?
    lastLoginAt   DateTime?
    createdAt     DateTime  @default(now())
    updatedAt     DateTime  @updatedAt

    // Relations
    branch           Branch?          @relation(fields: [branchId], references: [id])
    roleRelation     Role?            @relation(fields: [roleId], references: [id])
    transactions     Transaction[]
    shifts           Shift[]
    activityLogs     ActivityLog[]
    sessions         Session[]
    accessibleStores UserStore[]      // Multi-store access
    storeRequests    StoreRequest[]   @relation("RequestedBy")
    reviewedRequests StoreRequest[]   @relation("ReviewedBy")

    @@map("users")
}

// ═══════════════════════════════════════════════════════════════════════════
// STORE MANAGEMENT (Multi-store per Branch)
// ═══════════════════════════════════════════════════════════════════════════

model Store {
    id          String   @id @default(auto()) @map("_id") @db.ObjectId
    name        String
    code        String   @unique
    branchId    String   @db.ObjectId
    address     String?
    phone       String?
    email       String?
    description String?
    isActive    Boolean  @default(true)
    isDefault   Boolean  @default(false)
    settings    Json?
    createdAt   DateTime @default(now())
    updatedAt   DateTime @updatedAt

    // Relations
    branch       Branch      @relation(fields: [branchId], references: [id])
    userAccess   UserStore[]
    products     ProductStore[]

    @@map("stores")
}

model UserStore {
    id          String   @id @default(auto()) @map("_id") @db.ObjectId
    userId      String   @db.ObjectId
    storeId     String   @db.ObjectId
    branchId    String   @db.ObjectId
    isDefault   Boolean  @default(false)
    canRead     Boolean  @default(true)
    canWrite    Boolean  @default(true)
    canDelete   Boolean  @default(false)
    canManage   Boolean  @default(false)  // Can manage store settings
    assignedBy  String?  @db.ObjectId
    assignedAt  DateTime @default(now())
    createdAt   DateTime @default(now())
    updatedAt   DateTime @updatedAt

    // Relations
    user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
    store  Store  @relation(fields: [storeId], references: [id], onDelete: Cascade)
    branch Branch @relation(fields: [branchId], references: [id])

    @@unique([userId, storeId])
    @@map("user_stores")
}

model ProductStore {
    id          String   @id @default(auto()) @map("_id") @db.ObjectId
    productId   String   @db.ObjectId
    storeId     String   @db.ObjectId
    isActive    Boolean  @default(true)
    price       Float?   // Store-specific price override
    stock       Float    @default(0)
    minStock    Int      @default(10)
    createdAt   DateTime @default(now())
    updatedAt   DateTime @updatedAt

    // Relations
    product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
    store   Store   @relation(fields: [storeId], references: [id], onDelete: Cascade)

    @@unique([productId, storeId])
    @@map("product_stores")
}

// ═══════════════════════════════════════════════════════════════════════════
// STORE REQUEST (Super Admin Approval System)
// ═══════════════════════════════════════════════════════════════════════════

model StoreRequest {
    id            String   @id @default(auto()) @map("_id") @db.ObjectId
    requesterId   String   @db.ObjectId
    branchId      String?  @db.ObjectId
    
    // Request Type
    type          String   // "new_store", "new_branch", "branch_update"
    
    // Store Info (for new_store requests)
    storeName     String?
    storeCode     String?
    storeAddress  String?
    storePhone    String?
    storeEmail    String?
    
    // Branch Info (for new_branch requests)
    branchName    String?
    branchCode    String?
    branchAddress String?
    branchPhone   String?
    branchEmail   String?
    
    // Request Details
    reason        String?
    documents     String[]  // Uploaded document URLs
    metadata      Json?     // Additional data
    
    // Status
    status        String    @default("pending") // pending, approved, rejected
    priority      String    @default("normal")  // low, normal, high, urgent
    
    // Review
    reviewerId    String?   @db.ObjectId
    reviewNote    String?
    reviewedAt    DateTime?
    
    createdAt     DateTime  @default(now())
    updatedAt     DateTime  @updatedAt
    expiresAt     DateTime? // Optional expiry date

    // Relations
    requester     User      @relation("RequestedBy", fields: [requesterId], references: [id])
    reviewer      User?     @relation("ReviewedBy", fields: [reviewerId], references: [id])
    branch        Branch?   @relation(fields: [branchId], references: [id])

    @@index([status, createdAt])
    @@index([requesterId])
    @@map("store_requests")
}

model Session {
    id           String   @id @default(auto()) @map("_id") @db.ObjectId
    userId       String   @db.ObjectId
    token        String   @unique
    refreshToken String   @unique
    device       String?
    ip           String?
    userAgent    String?
    expiresAt    DateTime
    createdAt    DateTime @default(now())

    user User @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@map("sessions")
}

model Role {
    id          String   @id @default(auto()) @map("_id") @db.ObjectId
    name        String   @unique
    displayName String
    description String?
    permissions String[]
    isSystem    Boolean  @default(false)
    createdAt   DateTime @default(now())
    updatedAt   DateTime @updatedAt

    users User[]

    @@map("roles")
}

// ═══════════════════════════════════════════════════════════════════════════
// PERMISSION MANAGEMENT (Dynamic Permissions)
// ═══════════════════════════════════════════════════════════════════════════

model PermissionGroup {
    id          String   @id @default(auto()) @map("_id") @db.ObjectId
    key         String   @unique
    label       String
    icon        String?
    color       String?
    order       Int      @default(0)
    isActive    Boolean  @default(true)
    createdAt   DateTime @default(now())
    updatedAt   DateTime @updatedAt

    permissions Permission[]

    @@map("permission_groups")
}

model Permission {
    id        String   @id @default(auto()) @map("_id") @db.ObjectId
    key       String   @unique
    label     String
    groupId   String   @db.ObjectId
    order     Int      @default(0)
    isActive  Boolean  @default(true)
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    group PermissionGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)

    @@map("permissions")
}

// ═══════════════════════════════════════════════════════════════════════════
// MENU PERMISSIONS (Tree Structure for Role-based Menu Access)
// ═══════════════════════════════════════════════════════════════════════════

model MenuPermission {
    id          String   @id @default(auto()) @map("_id") @db.ObjectId
    key         String   @unique
    label       String
    labelLao    String?
    icon        String?
    path        String?
    parentId    String?  @db.ObjectId
    order       Int      @default(0)
    isActive    Boolean  @default(true)
    createdAt   DateTime @default(now())
    updatedAt   DateTime @updatedAt

    parent   MenuPermission?  @relation("MenuHierarchy", fields: [parentId], references: [id], onDelete: NoAction, onUpdate: NoAction)
    children MenuPermission[] @relation("MenuHierarchy")

    @@index([parentId])
    @@map("menu_permissions")
}

// ═══════════════════════════════════════════════════════════════════════════
// BRANCH MANAGEMENT
// ═══════════════════════════════════════════════════════════════════════════

model Branch {
    id        String   @id @default(auto()) @map("_id") @db.ObjectId
    name      String
    code      String   @unique
    address   String?
    phone     String?
    email     String?
    taxId     String?
    logo      String?
    isActive  Boolean  @default(true)
    isMain    Boolean  @default(false)
    settings  Json?
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    // Relations
    users         User[]
    products      Product[]
    transactions  Transaction[]
    inventory     Inventory[]
    tables        Table[]
    orders        Order[]
    shifts        Shift[]
    cashRegisters CashRegister[]
    customers     Customer[]
    stores        Store[]        // Multi-store support
    userStores    UserStore[]    // User-store assignments
    storeRequests StoreRequest[] // Store/Branch requests

    @@map("branches")
}

// ═══════════════════════════════════════════════════════════════════════════
// PRODUCTS & INVENTORY
// ═══════════════════════════════════════════════════════════════════════════

model Category {
    id          String   @id @default(auto()) @map("_id") @db.ObjectId
    name        String
    slug        String   @unique
    description String?
    image       String?
    parentId    String?  @db.ObjectId
    sortOrder   Int      @default(0)
    isActive    Boolean  @default(true)
    createdAt   DateTime @default(now())
    updatedAt   DateTime @updatedAt

    parent   Category?  @relation("CategoryHierarchy", fields: [parentId], references: [id], onDelete: NoAction, onUpdate: NoAction)
    children Category[] @relation("CategoryHierarchy")
    products Product[]

    @@map("categories")
}

model Product {
    id                String   @id @default(auto()) @map("_id") @db.ObjectId
    name              String
    description       String?
    sku               String?  // Can be shared across multiple products
    barcode           String?  // Can be shared across multiple products
    categoryId        String?  @db.ObjectId
    branchId          String   @db.ObjectId
    price             Float
    cost              Float    @default(0)
    unit              String   @default("piece")
    image             String?
    images            String[]
    isActive          Boolean  @default(true)
    isVat             Boolean  @default(true)
    vatRate           Float    @default(7)
    trackStock        Boolean  @default(true)
    lowStockThreshold Int      @default(10)
    allowDecimal      Boolean  @default(false)
    sortOrder         Int      @default(0)
    tags              String[]
    attributes        Json?
    createdAt         DateTime @default(now())
    updatedAt         DateTime @updatedAt

    // Relations
    category         Category?           @relation(fields: [categoryId], references: [id])
    branch           Branch              @relation(fields: [branchId], references: [id])
    inventory        Inventory[]
    transactionItems TransactionItem[]
    orderItems       OrderItem[]
    skuVariants      SKUVariant[]
    bom              BillOfMaterial[]
    priceLevels      ProductPriceLevel[]
    stores           ProductStore[]      // Multi-store availability

    @@map("products")
}

model SKUVariant {
    id         String   @id @default(auto()) @map("_id") @db.ObjectId
    productId  String   @db.ObjectId
    sku        String   @unique
    barcode    String?  @unique
    name       String
    attributes Json // { size: "L", color: "Red" }
    price      Float?
    cost       Float?
    image      String?
    isActive   Boolean  @default(true)
    createdAt  DateTime @default(now())
    updatedAt  DateTime @updatedAt

    product   Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
    inventory Inventory[]

    @@map("sku_variants")
}

model Inventory {
    id           String    @id @default(auto()) @map("_id") @db.ObjectId
    productId    String    @db.ObjectId
    skuVariantId String?   @db.ObjectId
    branchId     String    @db.ObjectId
    quantity     Float     @default(0)
    reserved     Float     @default(0)
    available    Float     @default(0)
    location     String?
    batchNumber  String?
    expiryDate   DateTime?
    createdAt    DateTime  @default(now())
    updatedAt    DateTime  @updatedAt

    product    Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
    skuVariant SKUVariant? @relation(fields: [skuVariantId], references: [id])
    branch     Branch      @relation(fields: [branchId], references: [id])

    @@unique([productId, branchId, skuVariantId, batchNumber])
    @@map("inventory")
}

model StockMovement {
    id            String   @id @default(auto()) @map("_id") @db.ObjectId
    productId     String   @db.ObjectId
    branchId      String   @db.ObjectId
    type          String // IN, OUT, ADJUST, TRANSFER
    quantity      Float
    previousQty   Float
    newQty        Float
    unitCost      Float?   // Cost per unit for stock-in
    supplier      String?  // Supplier/vendor name
    reason        String?
    reference     String? // PO number, transaction ID, etc.
    referenceType String? // PURCHASE, SALE, ADJUSTMENT, TRANSFER
    userId        String   @db.ObjectId
    notes         String?
    expiryDate    DateTime? // Expiry date for perishable items
    batchNumber   String?  // Batch/lot number
    createdAt     DateTime @default(now())

    @@map("stock_movements")
}

model BillOfMaterial {
    id           String @id @default(auto()) @map("_id") @db.ObjectId
    productId    String @db.ObjectId
    ingredientId String @db.ObjectId
    quantity     Float
    unit         String
    cost         Float  @default(0)

    product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

    @@map("bill_of_materials")
}

model ProductPriceLevel {
    id           String @id @default(auto()) @map("_id") @db.ObjectId
    productId    String @db.ObjectId
    priceLevelId String @db.ObjectId
    price        Float

    product    Product    @relation(fields: [productId], references: [id], onDelete: Cascade)
    priceLevel PriceLevel @relation(fields: [priceLevelId], references: [id], onDelete: Cascade)

    @@unique([productId, priceLevelId])
    @@map("product_price_levels")
}

model PriceLevel {
    id          String   @id @default(auto()) @map("_id") @db.ObjectId
    name        String   @unique
    description String?
    isDefault   Boolean  @default(false)
    createdAt   DateTime @default(now())
    updatedAt   DateTime @updatedAt

    products ProductPriceLevel[]

    @@map("price_levels")
}

// ═══════════════════════════════════════════════════════════════════════════
// CUSTOMERS
// ═══════════════════════════════════════════════════════════════════════════

model Customer {
    id          String    @id @default(auto()) @map("_id") @db.ObjectId
    memberCode  String?   @unique
    name        String
    email       String?
    phone       String?
    address     String?
    taxId       String?
    birthDate   DateTime?
    gender      String?
    notes       String?
    points      Int       @default(0)
    totalSpent  Float     @default(0)
    visitCount  Int       @default(0)
    lastVisitAt DateTime?
    branchId    String?   @db.ObjectId
    isActive    Boolean   @default(true)
    createdAt   DateTime  @default(now())
    updatedAt   DateTime  @updatedAt

    branch        Branch?         @relation(fields: [branchId], references: [id])
    transactions  Transaction[]
    pointsHistory PointsHistory[]

    @@map("customers")
}

model PointsHistory {
    id          String   @id @default(auto()) @map("_id") @db.ObjectId
    customerId  String   @db.ObjectId
    points      Int      // positive = add, negative = deduct
    type        String   // EARN, REDEEM, ADJUST, EXPIRE
    reason      String?
    referenceId String?  // transactionId or other reference
    createdBy   String?  @db.ObjectId
    createdAt   DateTime @default(now())

    customer Customer @relation(fields: [customerId], references: [id])

    @@index([customerId])
    @@map("points_history")
}

// ═══════════════════════════════════════════════════════════════════════════
// SALES & TRANSACTIONS
// ═══════════════════════════════════════════════════════════════════════════

model Transaction {
    id             String   @id @default(auto()) @map("_id") @db.ObjectId
    transactionNo  String   @unique
    type           String   @default("SALE") // SALE, REFUND, VOID
    status         String   @default("COMPLETED") // PENDING, COMPLETED, VOIDED, REFUNDED
    branchId       String   @db.ObjectId
    userId         String   @db.ObjectId
    shiftId        String?  @db.ObjectId
    memberId       String?  @db.ObjectId
    customerId     String?  @db.ObjectId
    tableId        String?  @db.ObjectId
    orderId        String?  @db.ObjectId
    orderType      String   @default("WALKIN") // WALKIN, TAKEAWAY, DELIVERY, DINE_IN
    subtotal       Float
    discountType   String? // PERCENTAGE, FIXED
    discountValue  Float    @default(0)
    discountAmount Float    @default(0)
    taxAmount      Float    @default(0)
    serviceCharge  Float    @default(0)
    total          Float
    received       Float    @default(0)
    change         Float    @default(0)
    pointsEarned   Int      @default(0)
    pointsRedeemed Int      @default(0)
    note           String?
    voidReason     String?
    refundReason   String?
    parentId       String?  @db.ObjectId // For refunds
    // Credit sale fields
    isCredit       Boolean  @default(false)
    creditStatus   String?  // PENDING, PARTIAL, PAID, OVERDUE
    dueDate        DateTime?
    paidAmount     Float    @default(0)
    createdAt      DateTime @default(now())
    updatedAt      DateTime @updatedAt

    // Relations
    branch   Branch               @relation(fields: [branchId], references: [id])
    user     User                 @relation(fields: [userId], references: [id])
    shift    Shift?               @relation(fields: [shiftId], references: [id])
    member   Member?              @relation(fields: [memberId], references: [id])
    customer Customer?            @relation(fields: [customerId], references: [id])
    items    TransactionItem[]
    payments TransactionPayment[]

    @@map("transactions")
}

model TransactionItem {
    id             String  @id @default(auto()) @map("_id") @db.ObjectId
    transactionId  String  @db.ObjectId
    productId      String  @db.ObjectId
    productName    String
    sku            String?
    barcode        String?
    quantity       Float
    unitPrice      Float
    cost           Float   @default(0)
    discountType   String?
    discountValue  Float   @default(0)
    discountAmount Float   @default(0)
    taxRate        Float   @default(0)
    taxAmount      Float   @default(0)
    total          Float
    note           String?
    modifiers      Json?

    transaction Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
    product     Product     @relation(fields: [productId], references: [id])

    @@map("transaction_items")
}

model TransactionPayment {
    id            String   @id @default(auto()) @map("_id") @db.ObjectId
    transactionId String   @db.ObjectId
    methodId      String   @db.ObjectId
    methodName    String
    amount        Float
    reference     String?
    createdAt     DateTime @default(now())

    transaction   Transaction   @relation(fields: [transactionId], references: [id], onDelete: Cascade)
    paymentMethod PaymentMethod @relation(fields: [methodId], references: [id])

    @@map("transaction_payments")
}

model HeldSale {
    id        String   @id @default(auto()) @map("_id") @db.ObjectId
    name      String?
    branchId  String   @db.ObjectId
    userId    String   @db.ObjectId
    memberId  String?  @db.ObjectId
    tableId   String?  @db.ObjectId
    items     Json // Cart items
    subtotal  Float
    discount  Float    @default(0)
    total     Float
    note      String?
    createdAt DateTime @default(now())

    @@map("held_sales")
}

// ═══════════════════════════════════════════════════════════════════════════
// SHIFTS & CASH MANAGEMENT
// ═══════════════════════════════════════════════════════════════════════════

model Shift {
    id              String    @id @default(auto()) @map("_id") @db.ObjectId
    shiftNo         String    @unique
    branchId        String    @db.ObjectId
    userId          String    @db.ObjectId
    registerId      String?   @db.ObjectId
    openingBalance  Float
    closingBalance  Float?
    expectedBalance Float?
    difference      Float?
    status          String    @default("OPEN") // OPEN, CLOSED
    openedAt        DateTime  @default(now())
    closedAt        DateTime?
    notes           String?
    createdAt       DateTime  @default(now())
    updatedAt       DateTime  @updatedAt

    branch        Branch         @relation(fields: [branchId], references: [id])
    user          User           @relation(fields: [userId], references: [id])
    register      CashRegister?  @relation(fields: [registerId], references: [id])
    transactions  Transaction[]
    cashMovements CashMovement[]

    @@map("shifts")
}

model CashRegister {
    id        String   @id @default(auto()) @map("_id") @db.ObjectId
    name      String
    branchId  String   @db.ObjectId
    isActive  Boolean  @default(true)
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    branch Branch  @relation(fields: [branchId], references: [id])
    shifts Shift[]

    @@map("cash_registers")
}

model CashMovement {
    id        String   @id @default(auto()) @map("_id") @db.ObjectId
    shiftId   String   @db.ObjectId
    type      String // FLOAT, PICKUP, PAYOUT
    amount    Float
    reason    String?
    userId    String   @db.ObjectId
    createdAt DateTime @default(now())

    shift Shift @relation(fields: [shiftId], references: [id])

    @@map("cash_movements")
}

// ═══════════════════════════════════════════════════════════════════════════
// RESTAURANT MODULE
// ═══════════════════════════════════════════════════════════════════════════

model Table {
    id        String   @id @default(auto()) @map("_id") @db.ObjectId
    name      String
    branchId  String   @db.ObjectId
    areaId    String?  @db.ObjectId
    capacity  Int      @default(4)
    status    String   @default("AVAILABLE") // AVAILABLE, OCCUPIED, RESERVED, CLEANING
    posX      Float    @default(0)
    posY      Float    @default(0)
    shape     String   @default("SQUARE") // SQUARE, ROUND, RECTANGLE
    isActive  Boolean  @default(true)
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    branch Branch  @relation(fields: [branchId], references: [id])
    orders Order[]

    @@map("tables")
}

model Order {
    id          String    @id @default(auto()) @map("_id") @db.ObjectId
    orderNo     String    @unique
    branchId    String    @db.ObjectId
    tableId     String?   @db.ObjectId
    type        String    @default("DINE_IN") // DINE_IN, TAKEAWAY, DELIVERY
    status      String    @default("PENDING") // PENDING, PREPARING, READY, SERVED, COMPLETED, CANCELLED
    guestCount  Int       @default(1)
    subtotal    Float     @default(0)
    discount    Float     @default(0)
    tax         Float     @default(0)
    total       Float     @default(0)
    note        String?
    kitchenNote String?
    servedAt    DateTime?
    completedAt DateTime?
    createdAt   DateTime  @default(now())
    updatedAt   DateTime  @updatedAt

    branch Branch      @relation(fields: [branchId], references: [id])
    table  Table?      @relation(fields: [tableId], references: [id])
    items  OrderItem[]

    @@map("orders")
}

model OrderItem {
    id          String    @id @default(auto()) @map("_id") @db.ObjectId
    orderId     String    @db.ObjectId
    productId   String    @db.ObjectId
    productName String
    quantity    Float
    unitPrice   Float
    total       Float
    status      String    @default("PENDING") // PENDING, PREPARING, READY, SERVED, CANCELLED
    note        String?
    modifiers   Json?
    sentAt      DateTime?
    preparedAt  DateTime?
    createdAt   DateTime  @default(now())
    updatedAt   DateTime  @updatedAt

    order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
    product Product @relation(fields: [productId], references: [id])

    @@map("order_items")
}

model Reservation {
    id           String   @id @default(auto()) @map("_id") @db.ObjectId
    branchId     String   @db.ObjectId
    tableId      String?  @db.ObjectId
    memberId     String?  @db.ObjectId
    customerName String
    phone        String
    email        String?
    guestCount   Int
    date         DateTime
    time         String
    duration     Int      @default(120) // minutes
    status       String   @default("PENDING") // PENDING, CONFIRMED, CANCELLED, COMPLETED, NO_SHOW
    note         String?
    createdAt    DateTime @default(now())
    updatedAt    DateTime @updatedAt

    @@map("reservations")
}

// ═══════════════════════════════════════════════════════════════════════════
// CRM & MEMBERS
// ═══════════════════════════════════════════════════════════════════════════

model Member {
    id         String    @id @default(auto()) @map("_id") @db.ObjectId
    cardNumber String?   @unique
    firstName  String
    lastName   String?
    email      String?
    phone      String    @unique
    birthdate  DateTime?
    gender     String?
    address    String?
    tierId     String?   @db.ObjectId
    points     Int       @default(0)
    totalSpent Float     @default(0)
    visitCount Int       @default(0)
    isActive   Boolean   @default(true)
    notes      String?
    createdAt  DateTime  @default(now())
    updatedAt  DateTime  @updatedAt

    tier         MembershipTier? @relation(fields: [tierId], references: [id])
    transactions Transaction[]
    pointHistory PointHistory[]

    @@map("members")
}

model MembershipTier {
    id              String   @id @default(auto()) @map("_id") @db.ObjectId
    name            String   @unique
    minPoints       Int      @default(0)
    pointMultiplier Float    @default(1)
    discountPercent Float    @default(0)
    benefits        Json?
    color           String?
    sortOrder       Int      @default(0)
    isActive        Boolean  @default(true)
    createdAt       DateTime @default(now())
    updatedAt       DateTime @updatedAt

    members Member[]

    @@map("membership_tiers")
}

model PointHistory {
    id            String    @id @default(auto()) @map("_id") @db.ObjectId
    memberId      String    @db.ObjectId
    type          String // EARN, REDEEM, ADJUST, EXPIRE
    points        Int
    balance       Int
    reference     String?
    referenceType String?
    description   String?
    expiresAt     DateTime?
    createdAt     DateTime  @default(now())

    member Member @relation(fields: [memberId], references: [id], onDelete: Cascade)

    @@map("point_history")
}

model PointSettings {
    id                String   @id @default(auto()) @map("_id") @db.ObjectId
    pointsPerCurrency Float    @default(1) // 1 point per 1 baht
    minSpendToEarn    Float    @default(0)
    redemptionRate    Float    @default(1) // 1 point = 1 baht
    minPointsToRedeem Int      @default(100)
    expiryMonths      Int?     @default(12)
    isActive          Boolean  @default(true)
    createdAt         DateTime @default(now())
    updatedAt         DateTime @updatedAt

    @@map("point_settings")
}

// ═══════════════════════════════════════════════════════════════════════════
// PROMOTIONS & DISCOUNTS
// ═══════════════════════════════════════════════════════════════════════════

model Promotion {
    id           String    @id @default(auto()) @map("_id") @db.ObjectId
    name         String
    description  String?
    type         String // BUY_X_GET_Y, BUNDLE, PERCENTAGE, FIXED
    value        Float
    conditions   Json? // { minQty: 2, categoryId: "xxx" }
    applicableTo Json? // { products: [], categories: [], all: true }
    startDate    DateTime
    endDate      DateTime?
    isActive     Boolean   @default(true)
    priority     Int       @default(0)
    usageLimit   Int?
    usageCount   Int       @default(0)
    memberOnly   Boolean   @default(false)
    createdAt    DateTime  @default(now())
    updatedAt    DateTime  @updatedAt

    @@map("promotions")
}

model Coupon {
    id           String    @id @default(auto()) @map("_id") @db.ObjectId
    code         String    @unique
    name         String
    description  String?
    type         String // PERCENTAGE, FIXED
    value        Float
    minPurchase  Float     @default(0)
    maxDiscount  Float?
    startDate    DateTime
    endDate      DateTime?
    usageLimit   Int?
    usageCount   Int       @default(0)
    perUserLimit Int?      @default(1)
    isActive     Boolean   @default(true)
    createdAt    DateTime  @default(now())
    updatedAt    DateTime  @updatedAt

    @@map("coupons")
}

model Discount {
    id            String    @id @default(auto()) @map("_id") @db.ObjectId
    name          String
    description   String?
    discountType  String    @default("percentage") // percentage, fixed
    discountValue Float
    applyTo       String    @default("all") // all, category, product
    productIds    String[]  @db.ObjectId
    categoryIds   String[]  @db.ObjectId
    minQuantity   Int       @default(1)
    minPurchase   Float     @default(0)
    maxDiscount   Float?
    startDate     DateTime?
    endDate       DateTime?
    usageLimit    Int?
    usageCount    Int       @default(0)
    isActive      Boolean   @default(true)
    createdAt     DateTime  @default(now())
    updatedAt     DateTime  @updatedAt

    @@map("discounts")
}

model Settlement {
    id               String   @id @default(auto()) @map("_id") @db.ObjectId
    settlementDate   DateTime
    totalAmount      Float    @default(0)
    cashAmount       Float    @default(0)
    cardAmount       Float    @default(0)
    otherAmount      Float    @default(0)
    transactionCount Int      @default(0)
    status           String   @default("pending") // pending, completed
    settledBy        String?  @db.ObjectId
    notes            String?
    createdAt        DateTime @default(now())
    updatedAt        DateTime @updatedAt

    @@map("settlements")
}

// ═══════════════════════════════════════════════════════════════════════════
// VENDORS & PURCHASE ORDERS
// ═══════════════════════════════════════════════════════════════════════════

model Vendor {
    id           String   @id @default(auto()) @map("_id") @db.ObjectId
    name         String
    code         String?
    contactName  String?
    email        String?
    phone        String?
    address      String?
    taxId        String?
    paymentTerms Int      @default(30) // days
    notes        String?
    isActive     Boolean  @default(true)
    isStarred    Boolean  @default(false)
    createdAt    DateTime @default(now())
    updatedAt    DateTime @updatedAt

    purchaseOrders PurchaseOrder[]

    @@map("vendors")
}

model PurchaseOrder {
    id           String    @id @default(auto()) @map("_id") @db.ObjectId
    poNumber     String    @unique
    vendorId     String    @db.ObjectId
    branchId     String    @db.ObjectId
    status       String    @default("DRAFT") // DRAFT, PENDING, APPROVED, RECEIVED, CANCELLED
    subtotal     Float
    tax          Float     @default(0)
    discount     Float     @default(0)
    total        Float
    expectedDate DateTime?
    receivedDate DateTime?
    notes        String?
    approvedBy   String?   @db.ObjectId
    approvedAt   DateTime?
    createdBy    String    @db.ObjectId
    createdAt    DateTime  @default(now())
    updatedAt    DateTime  @updatedAt

    vendor Vendor              @relation(fields: [vendorId], references: [id])
    items  PurchaseOrderItem[]

    @@map("purchase_orders")
}

model PurchaseOrderItem {
    id              String @id @default(auto()) @map("_id") @db.ObjectId
    purchaseOrderId String @db.ObjectId
    productId       String @db.ObjectId
    productName     String
    quantity        Float
    receivedQty     Float  @default(0)
    unitCost        Float
    total           Float

    purchaseOrder PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)

    @@map("purchase_order_items")
}

model StockTransfer {
    id           String    @id @default(auto()) @map("_id") @db.ObjectId
    transferNo   String    @unique
    fromBranchId String    @db.ObjectId
    toBranchId   String    @db.ObjectId
    status       String    @default("PENDING") // PENDING, APPROVED, IN_TRANSIT, COMPLETED, CANCELLED
    notes        String?
    requestedBy  String    @db.ObjectId
    approvedBy   String?   @db.ObjectId
    approvedAt   DateTime?
    completedBy  String?   @db.ObjectId
    completedAt  DateTime?
    createdAt    DateTime  @default(now())
    updatedAt    DateTime  @updatedAt

    items StockTransferItem[]

    @@map("stock_transfers")
}

model StockTransferItem {
    id          String @id @default(auto()) @map("_id") @db.ObjectId
    transferId  String @db.ObjectId
    productId   String @db.ObjectId
    productName String
    quantity    Float
    receivedQty Float  @default(0)

    transfer StockTransfer @relation(fields: [transferId], references: [id], onDelete: Cascade)

    @@map("stock_transfer_items")
}

// ═══════════════════════════════════════════════════════════════════════════
// STOCK COUNTS
// ═══════════════════════════════════════════════════════════════════════════

model StockCount {
    id             String   @id @default(auto()) @map("_id") @db.ObjectId
    countNo        String   @unique
    branchId       String   @db.ObjectId
    date           DateTime @default(now())
    status         String   @default("pending") // pending, completed, cancelled
    notes          String?
    hasDiscrepancy Boolean  @default(false)
    countedBy      String   @db.ObjectId
    approvedBy     String?  @db.ObjectId
    approvedAt     DateTime?
    createdAt      DateTime @default(now())
    updatedAt      DateTime @updatedAt

    items StockCountItem[]

    @@map("stock_counts")
}

model StockCountItem {
    id          String @id @default(auto()) @map("_id") @db.ObjectId
    countId     String @db.ObjectId
    productId   String @db.ObjectId
    productName String
    systemQty   Float
    actualQty   Float
    difference  Float

    stockCount StockCount @relation(fields: [countId], references: [id], onDelete: Cascade)

    @@map("stock_count_items")
}

// ═══════════════════════════════════════════════════════════════════════════
// PAYMENTS
// ═══════════════════════════════════════════════════════════════════════════

model PaymentMethod {
    id        String   @id @default(auto()) @map("_id") @db.ObjectId
    name      String
    code      String   @unique
    type      String // CASH, CARD, QR, TRANSFER, WALLET
    icon      String?
    isActive  Boolean  @default(true)
    isDefault Boolean  @default(false)
    settings  Json?
    sortOrder Int      @default(0)
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    transactions TransactionPayment[]

    @@map("payment_methods")
}

// ═══════════════════════════════════════════════════════════════════════════
// DOCUMENTS
// ═══════════════════════════════════════════════════════════════════════════

model Document {
    id            String   @id @default(auto()) @map("_id") @db.ObjectId
    type          String // RECEIPT, INVOICE, TAX_INVOICE, QUOTATION, PO, CREDIT_NOTE
    documentNo    String   @unique
    referenceId   String   @db.ObjectId
    referenceType String // TRANSACTION, ORDER, PURCHASE_ORDER
    data          Json
    status        String   @default("CREATED") // CREATED, PRINTED, SENT, CANCELLED
    printCount    Int      @default(0)
    createdAt     DateTime @default(now())
    updatedAt     DateTime @updatedAt

    @@map("documents")
}

model DocumentTemplate {
    id        String   @id @default(auto()) @map("_id") @db.ObjectId
    type      String   @unique
    name      String
    template  String // HTML template
    settings  Json?
    isActive  Boolean  @default(true)
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@map("document_templates")
}

// ═══════════════════════════════════════════════════════════════════════════
// SETTINGS & CONFIGURATION
// ═══════════════════════════════════════════════════════════════════════════

model Settings {
    id        String   @id @default(auto()) @map("_id") @db.ObjectId
    category  String
    key       String
    value     Json
    branchId  String?  @db.ObjectId
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@unique([category, key, branchId])
    @@map("settings")
}

// ═══════════════════════════════════════════════════════════════════════════
// NOTIFICATIONS & ACTIVITY
// ═══════════════════════════════════════════════════════════════════════════

model Notification {
    id        String    @id @default(auto()) @map("_id") @db.ObjectId
    userId    String    @db.ObjectId
    type      String
    title     String
    message   String
    data      Json?
    isRead    Boolean   @default(false)
    readAt    DateTime?
    createdAt DateTime  @default(now())

    @@map("notifications")
}

model ActivityLog {
    id          String   @id @default(auto()) @map("_id") @db.ObjectId
    userId      String   @db.ObjectId
    action      String
    description String?
    entity      String?
    entityId    String?  @db.ObjectId
    metadata    Json?
    oldData     Json?
    newData     Json?
    ip          String?
    userAgent   String?
    createdAt   DateTime @default(now())

    user User @relation(fields: [userId], references: [id])

    @@index([userId])
    @@index([action])
    @@index([createdAt])
    @@map("activity_logs")
}
