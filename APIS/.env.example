# ═══════════════════════════════════════════════════════════════════════════
# KPOS - Environment Configuration
# ═══════════════════════════════════════════════════════════════════════════

# Application
NODE_ENV=development
API_PORT=5000

# MongoDB
MONGO_PORT=27017
MONGODB_URI=mongodb://localhost:27017/kpos_db?replicaSet=rs0

# Redis
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379

# RabbitMQ
RABBITMQ_PORT=5672
RABBITMQ_MANAGEMENT_PORT=15672
RABBITMQ_USER=kpos
RABBITMQ_PASS=kpos_secret
RABBITMQ_URL=amqp://localhost:5672

# JWT Authentication
JWT_SECRET=your-super-secret-jwt-key-change-in-production-min-32-chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Nginx (Production)
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443

# External Services (Optional)
LINE_NOTIFY_TOKEN=
SHOPEE_API_KEY=
SHOPEE_API_SECRET=
LAZADA_API_KEY=
LAZADA_API_SECRET=

# Payment Gateways
OMISE_PUBLIC_KEY=
OMISE_SECRET_KEY=
STRIPE_PUBLIC_KEY=
STRIPE_SECRET_KEY=

# Email Service
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@kpos.local

# SMS Service
SMS_API_KEY=
SMS_API_SECRET=
