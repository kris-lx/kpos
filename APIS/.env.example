# ═══════════════════════════════════════════════════════════════════════════
# KPOS - Environment Configuration
# ═══════════════════════════════════════════════════════════════════════════

# Application
NODE_ENV=development
PORT=5000
API_VERSION=v1

# ─── Database (PostgreSQL) ────────────────────────────────────────────────
DATABASE_URL=postgresql://kpos:kpos_secret@localhost:5432/kpos_db
# Optional read replica (falls back to primary if not set)
# DATABASE_READ_URL=postgresql://kpos:kpos_secret@localhost:5433/kpos_db

# ─── Redis (optional — caching, rate limiting) ───────────────────────────
REDIS_URL=redis://localhost:6379

# ─── RabbitMQ (optional — async workers) ─────────────────────────────────
# RABBITMQ_URL=amqp://kpos:kpos_secret@localhost:5672

# ─── JWT Authentication ──────────────────────────────────────────────────
JWT_SECRET=your-super-secret-jwt-key-change-in-production-min-32-chars
JWT_EXPIRES_IN=24h
JWT_REFRESH_EXPIRES_IN=7d

# ─── Cloudinary (optional — file/document uploads) ──────────────────────
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=

# ─── Web Push (VAPID) ────────────────────────────────────────────────────
# Generate new keys: node -e "const wp=require('web-push'); const k=wp.generateVAPIDKeys(); console.log(k)"
VAPID_PUBLIC_KEY=BEAcj2CdjDcDmDd6ZhNt_Kj1a6Sn60Ds-xsZfFEryK5tHtZdjiW-CsF8c6h3XwhQNz73hJLlZH0cqEmCk0eS7qM
VAPID_PRIVATE_KEY=9buKAkzg0uKKNdqhGmoLtWvy0gQpdqfslUplO8B4hWU
VAPID_SUBJECT=mailto:admin@kpos.local

# ─── LINE Notify ──────────────────────────────────────────────────────────
# LINE_NOTIFY_TOKEN=

# ─── External Services (optional) ────────────────────────────────────────
# SHOPEE_API_KEY=
# LAZADA_API_KEY=

# ─── Email (optional) ────────────────────────────────────────────────────
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# EMAIL_FROM=noreply@kpos.local
