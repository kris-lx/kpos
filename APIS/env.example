# Database Configuration
# DATABASE_URL: the running API — connect as the least-privilege `kpos_app`
# role (no SUPERUSER/BYPASSRLS) so Row-Level Security policies actually apply.
# DATABASE_MIGRATE_URL: migrations and seed scripts only (npm run db:migrate /
# db:seed*) — needs the superuser role since it runs DDL and writes across
# all tenants. Falls back to DATABASE_URL if unset (back-compat).
DATABASE_URL=postgresql://kpos_app:password@localhost:5432/kpos
DATABASE_MIGRATE_URL=postgresql://user:password@localhost:5432/kpos
DB_POOL_SIZE=10

# JWT Configuration
# Session is capped at SESSION_ABSOLUTE_HOURS from login regardless of refresh
# activity — once that cap is hit, refresh is rejected and the client is forced
# to log out. Keep JWT_EXPIRES_IN / JWT_REFRESH_EXPIRES_IN <= that cap.
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=20h
JWT_REFRESH_EXPIRES_IN=20h
SESSION_ABSOLUTE_HOURS=20

# Server Configuration
PORT=5000
NODE_ENV=production
API_BASE_URL=https://api.kpos.la
# Frontend origin — used to build redirect links (password reset, SSO
# callback landing page). Read as APP_URL, not FRONTEND_URL.
APP_URL=https://kpos.la
TZ=Asia/Vientiane

# Redis Configuration
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=

# RabbitMQ Configuration
RABBITMQ_URL=amqp://localhost:5672
RABBITMQ_QUEUE=kpos_events

# Email Configuration (Brevo/Sendinblue) — platform-default fallback used when
# a tenant hasn't configured their own provider under Settings > Integrations > Email
BREVO_API_KEY=your-brevo-api-key
BREVO_SENDER_EMAIL=noreply@kpos.la
BREVO_SENDER_NAME=KPOS

# Encryption key for per-tenant email provider credentials (Phase 11). Separate from
# JWT_SECRET on purpose — rotating one must not affect the other. Generate with:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CONFIG_ENCRYPTION_KEY=change-me-to-a-random-32-byte-hex-string

# HMAC key for activityLogs tamper-detection checksums. Separate from JWT_SECRET
# on purpose — rotating the JWT signing key must not invalidate historical audit
# checksums, and vice versa. Generate with:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUDIT_HMAC_SECRET=change-me-to-a-random-32-byte-hex-string

# Cloudinary Configuration
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret
CLOUDINARY_FOLDER=kpos

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# CORS Configuration
CORS_ORIGIN=https://kpos.la

# Logging
LOG_LEVEL=info

# Web Push (VAPID) — optional; push notifications are disabled with a console
# warning if unset. Generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@kpos.la

# OpenTelemetry — optional; spans print to console if unset (see
# src/instrumentation.ts)
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=kpos-api

# Seed Configuration (for development/testing only)
# WARNING: Only use these in development environments
SEED_ADMIN_EMAIL=your-admin-email@example.com
SEED_ADMIN_PASSWORD=your-strong-password-here
SEED_ADMIN_NAME=Admin
SEED_ADMIN_RESET_PASSWORD=
SEED_DEMO_PASSWORD=
