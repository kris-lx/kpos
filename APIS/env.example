# Database Configuration
DATABASE_URL=postgresql://user:password@localhost:5432/kpos
DB_POOL_SIZE=10

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# Server Configuration
PORT=3000
NODE_ENV=production
API_BASE_URL=https://api.kpos.la
FRONTEND_URL=https://kpos.la

# Redis Configuration
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=

# RabbitMQ Configuration
RABBITMQ_URL=amqp://localhost:5672
RABBITMQ_QUEUE=kpos_events

# Email Configuration (Brevo/Sendinblue)
BREVO_API_KEY=your-brevo-api-key
BREVO_SENDER_EMAIL=noreply@kpos.la
BREVO_SENDER_NAME=KPOS

# Cloudinary Configuration
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret
CLOUDINARY_FOLDER=kpos

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# CORS Configuration
CORS_ORIGIN=https://kpos.la

# Logging
LOG_LEVEL=info

# Seed Configuration (for development/testing only)
SEED_ADMIN_EMAIL=admin@kpos.la
SEED_ADMIN_PASSWORD=Admin@123456
SEED_ADMIN_NAME=Super Admin
